Options -Indexes
RewriteEngine On

# Block access to .env, .git, and other sensitive dotfiles
RedirectMatch 403 \.env(\.|$)
RedirectMatch 403 \.git$

# Block access to sensitive directories (allow /docs route through to index.php)
RewriteRule ^docs/?$ index.php [QSA,L]
RewriteRule ^(app|integrations|storage|tools|tests|docs)/ - [F,L]

# API routes
RewriteRule ^api/(.*)$ api/index.php [QSA,L]

# Admin routes
RewriteRule ^admin(.*)$ index.php [QSA,L]

# Redirect /index.php to root (prevents app 404 when DirectoryIndex sets REQUEST_URI=/index.php)
RewriteRule ^index\.php$ / [R=301,L,QSA]

# Route root explicitly (DirectoryIndex may not fire on all LiteSpeed configs)
RewriteRule ^$ index.php [QSA,L]

# All other routes - PHP serves views directly
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]

# ----------------------------------------------------------------------
# Browser caching — static assets
# ----------------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive on

    # Images, icons, video
    ExpiresByType image/webp       "access plus 1 year"
    ExpiresByType image/png        "access plus 1 year"
    ExpiresByType image/jpeg       "access plus 1 year"
    ExpiresByType image/gif        "access plus 1 year"
    ExpiresByType image/svg+xml    "access plus 1 year"
    ExpiresByType image/x-icon     "access plus 1 year"

    # CSS, JavaScript
    ExpiresByType text/css         "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/javascript  "access plus 1 year"

    # Fonts
    ExpiresByType font/woff2       "access plus 1 year"
    ExpiresByType font/woff        "access plus 1 year"
    ExpiresByType font/ttf         "access plus 1 year"
    ExpiresByType font/eot         "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    ExpiresByType application/font-woff  "access plus 1 year"

    # HTML, JSON, data — short cache
    ExpiresByType text/html        "access plus 0 seconds"
    ExpiresByType application/json "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
    # 1 year for fingerprinted assets (?v=xxx)
    <FilesMatch "\.(webp|png|jpg|jpeg|gif|svg|ico|css|js|woff2?|ttf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # No caching for admin/API responses
    <FilesMatch "index\.php$">
        Header set Cache-Control "private, no-store, no-cache, must-revalidate, max-age=0"
    </FilesMatch>
</IfModule>

# ----------------------------------------------------------------------
# Serve WebP when supported
# ----------------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_ACCEPT} image/webp
    RewriteCond %{REQUEST_URI} \.(png|jpg|jpeg)$
    RewriteCond %{DOCUMENT_ROOT}/%{REQUEST_URI}.webp -f
    RewriteRule ^(.+\.(png|jpg|jpeg))$ $1.webp [T=image/webp,E=webp:1,L]

    <IfModule mod_headers.c>
        Header append Vary Accept env=webp
    </IfModule>
</IfModule>
