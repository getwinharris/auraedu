{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "bapXaura CTO handoff",
  "type": "object",
  "required": ["issue", "role", "objectives", "commands_run", "risks", "next_role"],
  "properties": {
    "issue": {"type": "integer", "minimum": 1},
    "role": {"enum": ["worker", "reviewer", "cto"]},
    "objectives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "status", "evidence", "browser_evidence", "unresolved"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "status": {"enum": ["pass", "gap", "blocked"]},
          "evidence": {"type": "array", "items": {"type": "string"}},
          "browser_evidence": {"type": "array", "items": {"type": "string"}},
          "unresolved": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    },
    "files_changed": {"type": "array", "items": {"type": "string"}},
    "commands_run": {"type": "array", "items": {"type": "string"}},
    "risks": {"type": "array", "items": {"type": "string"}},
    "next_role": {"enum": ["worker", "reviewer", "cto", "complete"]},
    "before_objective_hooks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "execute"],
        "properties": {
          "name": {"type": "string"},
          "execute": {"type": "string", "description": "PHP code or CLI command to block/audit an objective before execution. Return 'block:reason' to block, 'pass' to allow."}
        },
        "additionalProperties": false
      }
    },
    "after_objective_hooks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "execute"],
        "properties": {
          "name": {"type": "string"},
          "execute": {"type": "string", "description": "PHP code or CLI command to transform/audit an objective result after execution. Receives outcome via stdin."}
        },
        "additionalProperties": false
      }
    },
    "execution_mode": {
      "type": "string",
      "enum": ["sequential", "parallel"],
      "description": "Objective execution mode: sequential (one-by-one) or parallel (preflight all then execute concurrently). Default: sequential."
    },
    "model_config": {
      "type": "object",
      "properties": {
        "provider": {"type": "string"},
        "model": {"type": "string"},
        "endpoint": {"type": "string"},
        "api_key_prefix": {"type": "string"}
      },
      "description": "AI model config snapshot from SecretService::getModelConfig() at handoff time."
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "timestamp"],
        "properties": {
          "type": {"type": "string", "enum": ["handoff_start", "handoff_end", "objective_start", "objective_end", "objective_blocked", "hook_triggered", "hook_failed"]},
          "timestamp": {"type": "string"},
          "objective_id": {"type": "string"},
          "hook_name": {"type": "string"},
          "detail": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
