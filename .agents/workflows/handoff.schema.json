{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "bapXaura handoff event",
  "type": "object",
  "required": ["schema_version", "event_id", "issue", "from_role", "to_role", "status", "owner"],
  "properties": {
    "schema_version": {"type": "string", "const": "1.0"},
    "event_id": {"type": "string", "pattern": "^EVT-"},
    "workflow_id": {"type": "string", "pattern": "^WF-ISSUE-"},
    "issue": {"type": "integer", "minimum": 1},
    "pull_request": {"type": "integer", "minimum": 1},
    "from_role": {"enum": ["cto", "worker", "reviewer", "fixer", "documenter", "final_verifier", "deployment", "browser-tester"]},
    "to_role": {"enum": ["cto", "worker", "reviewer", "fixer", "documenter", "final_verifier", "deployment", "merge_bot", "owner"]},
    "objective_id": {"type": "string", "pattern": "^OBJ-"},
    "head_sha": {"type": "string", "pattern": "^[0-9a-f]{7,40}$"},
    "status": {"enum": ["ready", "in_progress", "approved", "changes_required", "blocked", "completed", "failed"]},
    "blocking_findings": {"type": "array", "items": {"type": "string"}},
    "owner": {
      "type": "object",
      "required": ["github", "notify", "reason"],
      "properties": {
        "github": {"type": "string", "const": "getwinharris"},
        "notify": {"type": "boolean"},
        "reason": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    },
    "objectives": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status", "evidence", "unresolved"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "status": {"enum": ["pass", "gap", "blocked", "in_progress"]},
          "evidence": {"type": "array", "items": {"type": "string"}},
          "browser_evidence": {"type": "array", "items": {"type": "string"}},
          "unresolved": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    },
    "files_changed": {"type": "array", "items": {"type": "string"}},
    "commands_run": {"type": "array", "items": {"type": "string"}},
    "risks": {"type": "array", "items": {"type": "string"}},
    "model_config": {
      "type": "object",
      "properties": {
        "provider": {"type": "string"},
        "model": {"type": "string"},
        "endpoint": {"type": "string"},
        "api_key_prefix": {"type": "string"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
