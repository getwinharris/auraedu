#!/usr/bin/env bash
set -euo pipefail

root=$(git rev-parse --show-toplevel)
cd "$root"

while IFS= read -r file; do
  [ -f "$file" ] || continue
  case "$file" in
    *.php) php -l "$file" >/dev/null ;;
    .agents/handoffs/*.json) php cli/handoff.php validate "$file" >/dev/null ;;
  esac
done < <(git diff --cached --name-only --diff-filter=ACMR)
