cmd_ci() {
  require_php
  local failed=0

  echo "── lint ──"
  cmd_lint || { failed=1; warn "LINT FAILED"; }

  echo "── test ──"
  cmd_test || { failed=1; warn "TESTS FAILED"; }

  echo "── map:val ──"
  php "$ROOT/cli/validate-project-map.php" 2>&1 || { failed=1; warn "MAP VALIDATION FAILED"; }

  echo "── docsmap:val ──"
  php "$ROOT/cli/validate-docs-map.php" "$ROOT" 2>&1 || { failed=1; warn "DOCS MAP VALIDATION FAILED"; }

  echo "── codemap:val (root map.mmd) ──"
  php "$ROOT/cli/generate-code-map.php" "$ROOT" "$ROOT/.map.mmd.tmp"
  if [ -f "$ROOT/map.mmd" ]; then
    if ! diff -q "$ROOT/map.mmd" "$ROOT/.map.mmd.tmp" >/dev/null 2>&1; then
      warn "CODE MAP STALE. Run bapXaura codemap and commit map.mmd."
      failed=1
    else
      ok "Code map is current"
    fi
  else
    warn "map.mmd missing. Run bapXaura codemap."
    failed=1
  fi
  rm -f "$ROOT/.map.mmd.tmp"

  echo "── smoke ──"
  php "$ROOT/cli/smoke-local.php" 2>&1 || { failed=1; warn "SMOKE FAILED"; }

  if [ "$failed" -eq 0 ]; then
    ok "ALL CHECKS PASSED"
  else
    err "SOME CHECKS FAILED"
    exit 1
  fi
}

