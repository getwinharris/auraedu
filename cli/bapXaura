cmd_agent_listen() {
  require_php
  echo "Agent runtime listening for handoff events..."
  echo "PID: $$"
  local events_dir="$ROOT/.agents/handoffs/events"
  local processed_file="$ROOT/.tmp/agent-processed.log"
  mkdir -p "$ROOT/.tmp"
  touch "$processed_file"
  while true; do
    for event_file in "$events_dir"/*.json; do
      [ -f "$event_file" ] || continue
      local event_name
      event_name=$(basename "$event_file")
      if grep -q "$event_name" "$processed_file" 2>/dev/null; then
        continue
      fi
      echo "[$(date '+%H:%M:%S')] Processing: $event_name"
      php -r '
        require "'"$ROOT"'/app/bootstrap.php";
        $file = "'"$event_file"'";
        $data = json_decode(file_get_contents($file), true);
        if (!$data) { echo "  Invalid JSON\n"; exit(1); }
        $runtime = new App\Services\AgentRuntimeService();
        $result = $runtime->executeHandoff($data, []);
        echo "  Role: " . ($data["to_role"] ?? "?") . "\n";
        echo "  Issue: #" . ($data["issue"] ?? "?") . "\n";
        echo "  Status: " . ($result["handled"] ? "processed" : "failed") . "\n";
      ' 2>&1
      echo "$event_name" >> "$processed_file"
    done
    sleep 10
  done
}

cmd_agent_prompt() {
  local message="$*"
  if [ -z "$message" ]; then
    echo "Usage: bapXaura agent:prompt <role> <issue> <message>"
    echo ""
    echo "Prompt a cloud agent role directly."
    echo ""
    echo "Examples:"
    echo '  bapXaura agent:prompt cto 42 "Implement hospital listing feature"'
    echo '  bapXaura agent:prompt worker 43 "Add search to hospitals page"'
    return 0
  fi
  local role="${1:-cto}"
  local issue="${2:-0}"
  shift 2 2>/dev/null || true
  local text="$*"
  if [ -z "$text" ]; then
    echo "Error: message text required"
    return 1
  fi
  local endpoint="${BAPX_AGENT_URL:-${APP_URL%/}/api/agent/prompt}"
  echo "Prompting $role agent for issue #$issue..."
  local response
  response=$(curl -s -X POST "$endpoint" \
    -H 'Content-Type: application/json' \
    -d "$(printf '{"role":"%s","issue":%d,"title":"Agent Prompt","message":"%s"}' "$role" "$issue" "$(echo "$text" | sed 's/"/\\"/g')")" \
    --connect-timeout 10 --max-time 120 2>&1)
  if [ $? -ne 0 ]; then
    echo "Error: Could not reach agent at $endpoint"
    return 1
  fi
  echo "$response" | python3 -c "
import sys, json
d = json.load(sys.stdin)
resp = d.get('response', d.get('error', 'Unknown'))
print(resp)
" 2>/dev/null || echo "$response"
}

cmd_agent() {
  local message="$*"
  if [ -z "$message" ]; then
    echo "Usage: bapXaura agent <message>"
    echo ""
    echo "Chat with the site AI agent."
    echo ""
    echo "Examples:"
    echo "  bapXaura agent how many users do we have"
    echo "  bapXaura agent what's the revenue this month"
    echo "  bapXaura agent create a blog post about Diwali offers"
    return 0
  fi
  local endpoint="${BAPX_AGENT_URL:-${APP_URL%/}/api/agent}"
  echo "Agent: thinking..."
  local response
  response=$(curl -s -X POST "$endpoint" \
    -H 'Content-Type: application/json' \
    -d "$(printf '{"message":"%s","source":"cli"}' "$(echo "$message" | sed 's/"/\\"/g')")" \
    --connect-timeout 10 --max-time 60 2>&1)
  if [ $? -ne 0 ]; then
    echo "Error: Could not reach agent at $endpoint"
    echo "Set BAPX_AGENT_URL env var for a different endpoint, or check your connection."
    return 1
  fi
  local answer
  answer=$(echo "$response" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('answer','') or d.get('error','Unknown error'))" 2>/dev/null)
  if [ -z "$answer" ]; then
    echo "Error parsing response: $answer"
    return 1
  fi
  echo ""
  echo "$answer"
}

# ═══════════════════════════════════════════════════════════════
# Database Commands (db) — MySQL direct connection
# Subcommands: tables, describe, list, show, query, find, raw, upsert, delete, remote-status, init, sync
# ═══════════════════════════════════════════════════════════════
# The `db` command suite lets the agent query and inspect project data
# from MySQL. All queries hit the live database.
#
# See the collections.php schema for the authoritative field definitions.
# JSON collection name == MySQL table name (underscored).
#
# MySQL schema per table:
#   id          VARCHAR(36) PK   — record ID (matches JSON primary_key)
#   _data       JSON NOT NULL    — full record data (same as JSON file contents)
#   _owner      VARCHAR(255)     — owner email (for owner_field collections)
#   _status     VARCHAR(50)      — record status (for indexed lookups)
#   _created_at DATETIME         — creation timestamp
#   _updated_at DATETIME         — last update timestamp
# ═══════════════════════════════════════════════════════════════

# ── db <command> ───────────────────────────────────────────────
# Entry point: bapXaura db <subcommand> [args]
# Subcommands: tables, describe, list, show, query, find, raw, init, sync
cmd_db() {
  local action="${1:-help}"
  shift 2>/dev/null || true
  case "$action" in
    tables|list)      cmd_db_tables "$@" ;;
    describe|desc)    cmd_db_describe "$1" ;;
    show)             cmd_db_show "$1" ;;
    query)            cmd_db_query "$@" ;;
    find)             cmd_db_find "$1" "$2" ;;
    raw|sql)          cmd_db_raw "$*" ;;
    upsert)           cmd_db_upsert "$1" "$2" ;;
    delete)           cmd_db_delete "$1" "$2" ;;
    status|remote-status) cmd_db_remote_status ;;
    pma)              cmd_db_pma "$*" ;;
    hosted|ssh-sql)   cmd_db_hosted_sql "$*" ;;
    init)             cmd_db_init ;;
    sync|import)      cmd_db_sync ;;
    help|*)           cmd_db_help ;;
  esac
}

cmd_db_help() {
  echo "Database commands — query MySQL directly, or via /remoteDB web proxy when local MySQL is unavailable."
  echo ""
  echo "  bapXaura db tables              — list MySQL tables"
  echo "  bapXaura db describe <table>    — describe MySQL table columns"
  echo "  bapXaura db list                — list all collections from schema"
  echo "  bapXaura db show <collection>   — show schema collection fields"
  echo "  bapXaura db query <collection> [--where 'f=v'] [--limit N] [--id id]"
  echo "  bapXaura db find <collection> <id>  — find record by ID"
  echo "  bapXaura db raw <sql>           — execute raw SQL via remote endpoint"
  echo "  bapXaura db upsert <collection> <json> — upsert record via remote endpoint"
  echo "  bapXaura db delete <collection> <id>   — delete record via remote endpoint"
  echo "  bapXaura db status              — verify DB paths and integration readiness"
  echo "  bapXaura db pma <sql>           — execute SQL via phpMyAdmin web proxy"
  echo "  bapXaura db hosted <sql>        — execute SQL on hosted MySQL through SSH"
  echo "  bapXaura db init                — create MySQL tables from collections.php"
  echo "  bapXaura db sync                — push JSON data files → MySQL tables"
  echo ""
  echo "Config env vars: BAPX_MYSQL_HOST, BAPX_MYSQL_DB, BAPX_MYSQL_USER, BAPX_MYSQL_PASS"
  echo "Remote endpoint: $REMOTE_DB_URL"
}

cmd_db_remote_status() {
  require_php
  echo "Runtime data store: remote MySQL"
  echo "Remote endpoint: $REMOTE_DB_URL"
  php -r '
    require $argv[1] . "/app/bootstrap.php";
    $cfg = require $argv[1] . "/config/database.php";
    try {
      $dsn = "mysql:host={$cfg["host"]};port={$cfg["port"]};dbname={$cfg["dbname"]};charset=utf8mb4";
      new PDO($dsn, $cfg["user"], $cfg["pass"], [PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION, PDO::ATTR_TIMEOUT => 4]);
      echo "Direct MySQL: connected\n";
    } catch (Throwable) {
      echo "Direct MySQL: unavailable from this machine; using /remotedb fallback\n";
    }
    $secrets = (new App\Services\SecretService())->all();
    foreach (["razorpay" => ["razorpay_key_id", "razorpay_key_secret"], "google_oauth" => ["google_client_id", "google_client_secret"], "smtp" => ["smtp_host", "smtp_username", "smtp_password"]] as $name => $keys) {
      $ready = count(array_filter($keys, fn($key) => trim((string)($secrets[$key] ?? "")) !== "")) === count($keys);
      echo "Integration {$name}: " . ($ready ? "configured" : "incomplete") . "\n";
    }
  ' "$ROOT"
  curl -fsS --max-time 12 -X POST "$REMOTE_DB_URL" -H "Content-Type: application/json" -d '{"query":"SELECT 1"}' >/dev/null \
    && echo "Remote endpoint: reachable" \
    || { echo "Remote endpoint: unavailable"; return 1; }
}

cmd_db_upsert() {
  local collection="$1" record="$2"
  [ -n "$collection" ] && [ -n "$record" ] || die "Usage: bapXaura db upsert <collection> '<json record>'"
  php -r 'json_decode($argv[1], true, 512, JSON_THROW_ON_ERROR);' "$record" >/dev/null 2>&1 || die "Record must be valid JSON."
  local payload
  payload=$(php -r 'echo json_encode(["action"=>"upsert","collection"=>$argv[1],"record"=>json_decode($argv[2],true,512,JSON_THROW_ON_ERROR)]);' "$collection" "$record") || die "Unable to encode record."
  curl -sS --max-time 15 -X POST "$REMOTE_DB_URL" \
    -H "Content-Type: application/json" \
    -d "$payload" \
    | php -r '
      $result = json_decode(file_get_contents("php://stdin"), true) ?: [];
      if (empty($result["success"])) { fwrite(STDERR, "Remote mutation failed: " . ($result["error"] ?? "Unknown error") . "\n"); exit(1); }
      echo json_encode($result, JSON_UNESCAPED_UNICODE) . "\n";
    '
}

cmd_db_delete() {
  local collection="$1" id="$2"
  [ -n "$collection" ] && [ -n "$id" ] || die "Usage: bapXaura db delete <collection> <id>"
  local payload
  payload=$(php -r 'echo json_encode(["action"=>"delete","collection"=>$argv[1],"id"=>$argv[2]]);' "$collection" "$id")
  curl -sS --max-time 15 -X POST "$REMOTE_DB_URL" \
    -H "Content-Type: application/json" \
    -d "$payload" \
    | php -r '
      $result = json_decode(file_get_contents("php://stdin"), true) ?: [];
      if (empty($result["success"])) { fwrite(STDERR, "Remote mutation failed: " . ($result["error"] ?? "Unknown error") . "\n"); exit(1); }
      echo json_encode($result, JSON_UNESCAPED_UNICODE) . "\n";
    '
}

