# ── Schema Commands ────────────────────────────────────────────
cmd_schema() {
  local action="${1:-list}"
  shift 2>/dev/null || true
  case "$action" in
    list) cmd_schema_list "$@" ;;
    show) cmd_schema_show "$1" ;;
    *)    cmd_schema_list ;;
  esac
}

cmd_schema_list() {
  [ -f "$SCHEMA_FILE" ] || die "Schema file not found: $SCHEMA_FILE"
  php -r "
    \$s = require '$SCHEMA_FILE';
    echo \"Collections (\" . count(\$s['collections'] ?? []) . \"):\n\";
    foreach (\$s['collections'] ?? [] as \$name => \$col) {
      \$c = count(\$col['fields'] ?? []);
      echo \"  \$name  (\$c fields)\n\";
    }
  "
}

cmd_schema_show() {
  local collection="$1"
  [ -z "$collection" ] && die "Usage: bapXaura schema show <collection>"
  [ -f "$SCHEMA_FILE" ] || die "Schema file not found: $SCHEMA_FILE"
  php -r "
    \$s = require '$SCHEMA_FILE';
    \$col = \$s['collections']['$collection'] ?? null;
    if (!\$col) { fprintf(STDERR, \"Collection '$collection' not found\n\"); exit(1); }
    echo \"Collection: $collection\n\";
    echo \"Table:      \" . preg_replace('/[^a-z_]/', '', \$col['name'] ?? '$collection') . \"\n\";
    echo \"PKey:       \" . (\$col['primary_key'] ?? 'id') . \"\n\";
    echo \"Managed:    \" . (\$col['admin_managed'] ? 'admin' : 'runtime') . \"\n\";
    if (\$col['admin_fields'] ?? []) echo \"Admin flds: \" . implode(', ', \$col['admin_fields']) . \"\n\";
    if (\$col['media_fields'] ?? []) echo \"Media flds: \" . implode(', ', \$col['media_fields']) . \"\n\";
    if (\$col['agent_context'] ?? []) echo \"Context:    \" . implode(', ', \$col['agent_context']) . \"\n\";
    echo \"\nFields:\n\";
    foreach (\$col['fields'] ?? [] as \$fname => \$fdef) {
      \$req = !empty(\$fdef['required']) ? ' required' : '';
      \$vals = isset(\$fdef['values']) ? ' [' . implode(', ', \$fdef['values']) . ']' : '';
      \$items = isset(\$fdef['items']) ? ' of ' . \$fdef['items'] : '';
      echo \"  \$fname: \" . \$fdef['type'] . \$items . \$vals . \$req . \"\n\";
    }
  "
}

cmd_add() {
  local field_spec="" collection=""
  local args=()

  # Parse: bapXaura add <field>:<type> [opts] under <collection>
  while [ $# -gt 0 ]; do
    case "$1" in
      under) shift; collection="$1" ;;
      *) args+=("$1") ;;
    esac
    shift
  done

  [ -z "$collection" ] && die "Usage: bapXaura add <field>:<type> [modifiers] under <collection>"
  [ ${#args[@]} -eq 0 ] && die "Missing field spec. Usage: bapXaura add <field>:<type> under <collection>"

  field_spec="${args[0]}"
  local field_name="${field_spec%%:*}"
  local field_type="${field_spec#*:}"

  [ -z "$field_name" ] && die "Field name is required"
  [ -z "$field_type" ] && die "Field type is required (e.g. string, number, boolean, email, text, slug, url, datetime)"

  local required="false"
  local enum_values=""
  local items_type=""

  for ((i=1; i<${#args[@]}; i++)); do
    case "${args[$i]}" in
      required:*) required="${args[$i]#required:}" ;;
      values:*)   enum_values="${args[$i]#values:}" ;;
      items:*)    items_type="${args[$i]#items:}" ;;
    esac
  done

  [ -f "$SCHEMA_FILE" ] || die "Schema file not found: $SCHEMA_FILE"

  php -r "
    \$path = '$SCHEMA_FILE';
    \$s = require \$path;
    if (!isset(\$s['collections']['$collection'])) {
      fprintf(STDERR, \"Collection '$collection' not found\n\"); exit(1);
    }
    if (isset(\$s['collections']['$collection']['fields']['$field_name'])) {
      fprintf(STDERR, \"Field '$field_name' already exists in '$collection'\n\"); exit(1);
    }
    \$def = ['type' => '$field_type'];
    if ('$required' === 'true') \$def['required'] = true;
    if ('$enum_values' !== '') \$def['values'] = explode(',', '$enum_values');
    if ('$items_type' !== '') \$def['items'] = '$items_type';
    \$s['collections']['$collection']['fields']['$field_name'] = \$def;
    file_put_contents(\$path, '<?php return ' . var_export(\$s, true) . ';' . PHP_EOL);
    echo \"Added $field_name: $field_type to $collection\n\";
  "
}

cmd_remove() {
  local field_name="" collection=""
  local args=()

  while [ $# -gt 0 ]; do
    case "$1" in
      under) shift; collection="$1" ;;
      *) args+=("$1") ;;
    esac
    shift
  done

  [ -z "$collection" ] && die "Usage: bapXaura remove <field> under <collection>"
  [ ${#args[@]} -eq 0 ] && die "Missing field name. Usage: bapXaura remove <field> under <collection>"

  field_name="${args[0]}"
  [ -f "$SCHEMA_FILE" ] || die "Schema file not found: $SCHEMA_FILE"

  php -r "
    \$path = '$SCHEMA_FILE';
    \$s = require \$path;
    if (!isset(\$s['collections']['$collection'])) {
      fprintf(STDERR, \"Collection '$collection' not found\n\"); exit(1);
    }
    if (!isset(\$s['collections']['$collection']['fields']['$field_name'])) {
      fprintf(STDERR, \"Field '$field_name' not found in '$collection'\n\"); exit(1);
    }
    unset(\$s['collections']['$collection']['fields']['$field_name']);

    // Clean up related arrays
    foreach (['admin_fields', 'media_fields', 'agent_context'] as \$key) {
      if (isset(\$s['collections']['$collection'][\$key])) {
        \$s['collections']['$collection'][\$key] = array_values(array_filter(
          \$s['collections']['$collection'][\$key],
          fn(\$v) => \$v !== '$field_name'
        ));
        if (empty(\$s['collections']['$collection'][\$key])) unset(\$s['collections']['$collection'][\$key]);
      }
    }
    file_put_contents(\$path, '<?php return ' . var_export(\$s, true) . ';' . PHP_EOL);
    echo \"Removed $field_name from $collection\n\";
  "
}

