# ── db query <collection> [--where "field=value"] [--limit N] [--id id] [--owner email]
# ────────────────────────────────────────────────────────────────
# Queries a collection. Tries MySQL first, falls back to reading JSON file.
#   --where "field=value"   — filter records where _data->>"$.field" matches value
#   --id <id>               — shorthand: find by id column
#   --owner <email>         — shorthand: find by _owner column
#   --limit N               — max records to return (default: 50)
#   --json                  — output raw JSON (one record per line)
cmd_db_query() {
  require_php
  local collection="" where="" id_val="" owner_val="" limit=50 json_output=false
  local args=()

  while [ $# -gt 0 ]; do
    case "$1" in
      --where)    shift; where="$1" ;;
      --id)       shift; id_val="$1" ;;
      --owner)    shift; owner_val="$1" ;;
      --limit)    shift; limit="$1" ;;
      --json)     json_output=true ;;
      *)          args+=("$1") ;;
    esac
    shift
  done

  collection="${args[0]:-}"
  [ -z "$collection" ] && die "Usage: bapXaura db query <collection> [--where 'f=v'] [--id id] [--owner email] [--limit N]"

  # ── Query via remote DB endpoint ──
  local sql="SELECT * FROM $collection"
  [ -n "$id_val" ] && sql="$sql WHERE id = '$id_val'"
  [ -n "$owner_val" ] && sql="$sql AND _owner = '$owner_val'"
  [ -n "$limit" ] && sql="$sql LIMIT $limit"
  local resp
  resp=$(curl -s --max-time 15 -X POST "$REMOTE_DB_URL" \
    -H "Content-Type: application/json" \
    -d "$(php -r 'echo json_encode(["query" => $argv[1]]);' "$sql")" 2>&1) || { die "Remote DB unreachable."; }
  local data
  data=$(echo "$resp" | php -r '$r=json_decode(file_get_contents("php://stdin"),true);foreach(($r["data"]??[]) as $row){$d=json_decode($row["_data"]??"{}",true)?:[];$d["id"]=$row["id"]??"";echo json_encode($d,JSON_UNESCAPED_UNICODE)."\n";}')
  [ -z "$data" ] && { echo "No records found in $collection."; return; }
  local count
  count=$(echo "$data" | wc -l | tr -d ' ')
  echo "Found $count records in $collection:"
  echo ""
  if [ "$json_output" = "true" ]; then
    echo "$data"
  else
    echo "$data" | while IFS= read -r line; do
      php -r '
        $d = json_decode(file_get_contents("php://stdin"), true) ?: [];
        echo "  ID:   " . ($d["id"] ?? "") . PHP_EOL;
        foreach ($d as $k => $v) {
          if ($k === "id") continue;
          $val = is_array($v) ? json_encode($v) : $v;
          echo "  $k: $val\n";
        }
        echo "  ---\n";
      ' <<< "$line"
    done
  fi
}

# ── db find <collection> <id> ───────────────────────────────────
# Shorthand for bapXaura db query <collection> --id <id>
cmd_db_find() {
  local collection="$1" id="$2"
  [ -z "$collection" ] && die "Usage: bapXaura db find <collection> <id>"
  [ -z "$id" ] && die "Usage: bapXaura db find <collection> <id>"
  cmd_db_query "$collection" --id "$id"
}

# ── db raw <sql> — Execute raw SQL via remote endpoint ─────────────
# POSTs the SQL to the remote DB endpoint and outputs JSON lines.
cmd_db_raw() {
  local sql="$*"
  [ -z "$sql" ] && die "Usage: bapXaura db raw \"SELECT ...\""

  curl -s --max-time 15 -X POST "$REMOTE_DB_URL" \
    -H "Content-Type: application/json" \
    -d "$(php -r 'echo json_encode(["query" => $argv[1]]);' "$sql")" 2>&1 \
    | php -r '
      $r = json_decode(file_get_contents("php://stdin"), true);
      if (!empty($r["error"])) { fprintf(STDERR, "Error: %s\n", $r["error"]); exit(1); }
      $data = $r["data"] ?? [];
      if (empty($data)) { echo "No results.\n"; exit(0); }
      foreach ($data as $row) {
        $decoded = json_decode($row["_data"] ?? "{}", true) ?: [];
        $decoded["id"] = $row["id"] ?? "";
        echo json_encode($decoded, JSON_UNESCAPED_UNICODE) . "\n";
      }
    '
}

# ── db pma <sql> — Execute SQL via phpMyAdmin web proxy ──────────
# Always uses the phpMyAdmin web interface, bypassing direct MySQL limits.
cmd_db_pma() {
  local sql="$*"
  [ -z "$sql" ] && die "Usage: bapXaura db pma \"SELECT ...\" (or --table-stats, --export)"
  php "$ROOT/cli/pma-client.php" "$sql"
}

# ── db hosted <sql> — Execute SQL on hosting through SSH ───────
cmd_db_hosted_sql() {
  local sql="$*"
  [ -n "$sql" ] || die "Usage: bapXaura db hosted \"SELECT ...\""
  for name in BAPX_SSH_HOST BAPX_SSH_USER BAPX_SSH_PASS BAPX_MYSQL_DB BAPX_MYSQL_USER BAPX_MYSQL_PASS; do
    [ -n "${!name:-}" ] || die "$name is required in .env.mysql"
  done
  command -v sshpass >/dev/null 2>&1 || die "sshpass is required for non-interactive hosted DB operations."
  local remote_mysql_host="${BAPX_MYSQL_HOST:-localhost}"
  local remote_command
  printf -v remote_command 'MYSQL_PWD=%q mysql --batch --raw -h %q -P %q -u %q %q' \
    "$BAPX_MYSQL_PASS" "$remote_mysql_host" "${BAPX_MYSQL_PORT:-3306}" "$BAPX_MYSQL_USER" "$BAPX_MYSQL_DB"
  sshpass -p "$BAPX_SSH_PASS" ssh -o StrictHostKeyChecking=accept-new -p "${BAPX_SSH_PORT:-22}" \
    "$BAPX_SSH_USER@$BAPX_SSH_HOST" "$remote_command" <<< "$sql"
}

# ── db init — Create MySQL tables from collections.php schema ────
# Reads the schema file, creates MySQL tables with _data JSON column
# and indexed columns for commonly queried fields.
cmd_db_init() {
  require_php
  echo "Creating MySQL tables from collections.php schema..."

  # Prefer direct MySQL when reachable (e.g. on the host / SSH).
  if php -r "
    \$dsn = 'mysql:host=$MYSQL_HOST;port=$MYSQL_PORT;dbname=$MYSQL_DB;charset=utf8mb4';
    try { new PDO(\$dsn, '$MYSQL_USER', '$MYSQL_PASS', [PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION, PDO::ATTR_TIMEOUT => 5]); echo 'OK'; exit(0); }
    catch (\Throwable \$e) { exit(1); }
  " >/dev/null 2>&1; then
    php -r "
      \$dsn = 'mysql:host=$MYSQL_HOST;port=$MYSQL_PORT;dbname=$MYSQL_DB;charset=utf8mb4';
      \$pdo = new PDO(\$dsn, '$MYSQL_USER', '$MYSQL_PASS', [PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION, PDO::ATTR_TIMEOUT => 5]);
      \$schema = require '$SCHEMA_FILE';
      foreach (\$schema['collections'] as \$name => \$col) {
        \$table = preg_replace('/[^a-z_]/', '', \$name);
        \$pdo->exec(\"CREATE TABLE IF NOT EXISTS {\$table} (
          id VARCHAR(36) PRIMARY KEY,
          _data JSON NOT NULL,
          _owner VARCHAR(255) DEFAULT NULL,
          _status VARCHAR(50) DEFAULT NULL,
          _created_at DATETIME DEFAULT NULL,
          _updated_at DATETIME DEFAULT NULL,
          INDEX idx_owner (_owner),
          INDEX idx_status (_status),
          INDEX idx_created (_created_at)
        ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci\");
        echo \"  CREATED TABLE \$table\n\";
      }
      echo \"Done. \" . count(\$schema['collections']) . \" tables created.\n\";
    "
    return 0
  fi

  # Fallback: run init through the /remoteDB endpoint (works from anywhere).
  echo "Direct MySQL unavailable; using $REMOTE_DB_URL ..."
  curl -fsS --max-time 30 -X POST "$REMOTE_DB_URL" \
    -H "Content-Type: application/json" \
    -d "$(php -r 'echo json_encode(["action" => "init"]);')" 2>&1 \
    | php -r '$r = json_decode(file_get_contents("php://stdin"), true); if (!empty($r["error"])) { fprintf(STDERR, "Error: %s\n", $r["error"]); exit(1); } echo "  " . ($r["tables_created"] ?? 0) . " tables created via remote endpoint.\n";'
}

# ── db sync — Push JSON data files → MySQL tables ──────────────
# Reads every JSON data file defined in collections.php and inserts
# records into the corresponding MySQL table (INSERT IGNORE).
cmd_db_sync() {
  require_php

  # Test connection
  php -r "
    \$dsn = 'mysql:host=$MYSQL_HOST;port=$MYSQL_PORT;dbname=$MYSQL_DB;charset=utf8mb4';
    try { new PDO(\$dsn, '$MYSQL_USER', '$MYSQL_PASS', [PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION, PDO::ATTR_TIMEOUT => 5]); echo \"OK\n\"; exit(0); } catch (Exception \$e) {}
    echo \"FAIL\n\"; exit(1);
  " 2>/dev/null || die "Cannot connect to MySQL. Check config/database.php."

  echo "Pushing JSON collections into MySQL..."
  php -r "
    \$schema = require '$SCHEMA_FILE';

    \$dsn = 'mysql:host=$MYSQL_HOST;port=$MYSQL_PORT;dbname=$MYSQL_DB;charset=utf8mb4';
    \$pdo = new PDO(\$dsn, '$MYSQL_USER', '$MYSQL_PASS', [PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION, PDO::ATTR_TIMEOUT => 5]);

    \$total = 0;
    foreach (\$schema['collections'] as \$name => \$col) {
      \$table = preg_replace('/[^a-z_]/', '', \$name);

      // Ensure table exists
      \$pdo->exec(\"CREATE TABLE IF NOT EXISTS {\$table} (
        id VARCHAR(36) PRIMARY KEY,
        _data JSON NOT NULL,
        _owner VARCHAR(255) DEFAULT NULL,
        _status VARCHAR(50) DEFAULT NULL,
        _created_at DATETIME DEFAULT NULL,
        _updated_at DATETIME DEFAULT NULL
      ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4\");

      echo \"  CREATED \$table (no JSON files — data is in MySQL)\n\";
      if (\$name === 'consultation_signals') {
        try { \$pdo->exec(\"ALTER TABLE consultation_signals ADD COLUMN appointment_id VARCHAR(36) GENERATED ALWAYS AS (JSON_UNQUOTE(JSON_EXTRACT(_data, '$.appointment_id'))) STORED\"); } catch (\PDOException \$e) {}
        try { \$pdo->exec(\"CREATE INDEX idx_signals_appointment_id ON consultation_signals (appointment_id)\"); } catch (\PDOException \$e) {}
      }
      \$total++;
    }
    echo \"Done. \$total tables created.\n\";
  "
}

