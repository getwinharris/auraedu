cmd_tool_list() {
  echo "Tools in $ROOT/cli/:"
  echo ""
  for f in "$ROOT/cli/"*.php; do
    [ -f "$f" ] || continue
    local name
    name=$(basename "$f") || true
    local desc
    desc=$(head -3 "$f" | sed -n 's/.*\* *//p' | head -1) || true
    printf "  %s  %s\n" "$name" "$desc"
  done
  [ -x "$ROOT/bapXaura" ] && printf "  %s  %s\n" "bapXaura" "Project management CLI"
