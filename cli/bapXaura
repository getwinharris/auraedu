cmd_tool_add() {
  local filename="$1"
  [ -z "$filename" ] && die "Usage: bapXaura tool add <filename.php>"

  # Ensure .php extension
  [[ "$filename" == *.php ]] || filename="${filename}.php"
  local filepath="$ROOT/cli/$filename"

  [ -f "$filepath" ] && die "File already exists: $filepath"

  # Create template
  cat > "$filepath" << 'TEMPLATE'
<?php
/**
 * Short description of this tool.
 *
 * Usage: php cli/__FILE__
 */

require __DIR__ . '/../app/bootstrap.php';

// Your tool logic here
echo "Tool ready.\n";
TEMPLATE

  # Replace placeholder
  sed -i '' "s/__FILE__/$filename/" "$filepath"

  # Open in nano for editing
  nano "$filepath"

  # Validate
  if php -l "$filepath" 2>&1; then
    chmod +x "$filepath"
    ok "Created and validated: cli/$filename"
  else
    err "PHP syntax errors in $filename. Fix with: nano cli/$filename"
    exit 1
  fi
}

