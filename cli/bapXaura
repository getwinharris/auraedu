#!/usr/bin/env bash
# PHP polyglot guard — Issue #201. Allows `php cli/bapXaura <cmd>` to work.
: <<'BAP_PHP_GUARD'
<?php
if (PHP_SAPI === 'cli') {
    $args = $argv;
    $script = array_shift($args);
    $cmd = 'bash ' . escapeshellarg($script);
    foreach ($args as $a) $cmd .= ' ' . escapeshellarg($a);
    passthru($cmd, $rc);
    exit($rc);
}
__halt_compiler(); ?>
BAP_PHP_GUARD
set -euo pipefail

