cmd_repl() {
  local histfile="$ROOT/.tmp/repl_history.txt"
  mkdir -p "$ROOT/.tmp"
  touch "$histfile"
  printf "${B}${C}╔══════════════════════════════════════════════╗${N}\n"
  printf "${B}${C}║${N}  bapXaura REPL — bidirectional CLI shell   ${B}${C}║${N}\n"
  printf "${B}${C}╚══════════════════════════════════════════════╝${N}\n"
  echo "  Type any bapXaura command or enter AI prompts."
  echo "  Prefix with 'ai: ' to chat with the agent."
  echo "  Type 'help', 'exit', or Ctrl+D to quit."
  echo ""
  local branch
  branch=$(git -C "$ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null || echo '?')
  while true; do
    if ! read -r -e -p "bapX(${branch})> " line; then
      echo ""
      break
    fi
    history -s "$line"
    echo "$line" >> "$histfile"
    case "$line" in
      exit|quit|q)
        break ;;
      help)
        cmd_help ;;
      ai:*)
        local msg="${line#ai: }"
        local endpoint="${BAPX_AGENT_URL:-${APP_URL%/}/api/agent}"
        echo ""
        echo "  ⏳ thinking..."
        local resp
        resp=$(curl -s -X POST "$endpoint" \
          -H 'Content-Type: application/json' \
          -d "$(printf '{"message":"%s","source":"cli"}' "$(echo "$msg" | sed 's/"/\\"/g')")" \
          --connect-timeout 10 --max-time 60 2>&1) || true
        local answer
        answer=$(echo "$resp" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('answer','') or d.get('error','No response'))" 2>/dev/null)
        if [ -n "$answer" ]; then
          echo ""
          echo "$answer" | sed 's/^/  /'
        else
          echo "  Error: $resp"
        fi
        echo "" ;;
      "")
        continue ;;
      npm\ *)
        cd "$ROOT" && eval "${line}" 2>&1 | sed 's/^/  /' ;;
      *)
        cd "$ROOT" && eval "php cli/bapXaura ${line} 2>&1" | sed 's/^/  /' ;;
    esac
  done
  echo "bye!"
}

