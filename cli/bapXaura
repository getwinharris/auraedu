cmd_dev_user() {
  local dry_run=false
  local generate=false
  [ "${1:-}" = "--dry-run" ] && dry_run=true
  [ "${1:-}" = "--generate" ] && generate=true
  local id="${BAPX_TEST_USER_ID:-dev_test_customer}"
  local email="${BAPX_TEST_USER_EMAIL:-test.user@bapx.dev}"
  local name="${BAPX_TEST_USER_NAME:-Development Test User}"
  local password="${BAPX_TEST_USER_PASSWORD:-}"
  if [ "$generate" = true ] && [ -z "$password" ]; then
    command -v openssl >/dev/null 2>&1 || die "OpenSSL is required to generate the development password."
    password=$(openssl rand -base64 24 | tr -d '\r\n')
    umask 077
    printf 'BAPX_TEST_USER_PASSWORD=%s\n' "$password" > "$ROOT/.env.test-user"
  fi
  [ -n "$password" ] || die "Set BAPX_TEST_USER_PASSWORD in ignored operator config, or run bapXaura dev:user --generate."

  local record
  record=$(php -r '
    echo json_encode([
      "id"=>$argv[1], "email"=>$argv[2], "username"=>"dev_test_customer",
      "name"=>$argv[3], "role"=>"customer",
      "password_hash"=>password_hash($argv[4], PASSWORD_DEFAULT),
      "accepted_terms_at"=>date(DATE_ATOM), "development_fixture"=>true,
    ], JSON_UNESCAPED_SLASHES);
  ' "$id" "$email" "$name" "$password")

  if [ "$dry_run" = true ]; then
    echo "Would upsert fixed development customer: $id ($email)"
    return
  fi
  cmd_db_upsert users "$record" >/dev/null
  ok "Development customer ready: $id ($email)"
}

cmd_help() {
  awk '
    /^# [═╬]/ { c++; if (c == 2) { capturing = 1; next } if (c == 3) { exit } }
    capturing { sub(/^# ?/, ""); print }
  ' "${BASH_SOURCE[0]}"
  echo ""
  echo "Run 'bapXaura <command>' for command-specific help."
}

# ── understand ─────────────────────────────────────────────────
cmd_understand() {
  require_php

  local branch="" last_commit="" git_status="" dirty=""
  branch=$(git -C "$ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")
  last_commit=$(git -C "$ROOT" log --oneline -1 2>/dev/null || echo "?")
  dirty=$(git -C "$ROOT" status --short 2>/dev/null | wc -l | tr -d ' ')
  [ "$dirty" -gt 0 ] && git_status="${dirty} modified/staged" || git_status="clean"

  echo ""
  printf "${B}${C}%s${N}${B}%s${N}\n" "╔══════════════════════════════════════════╗" ""
  printf "${B}${C}%s${N}${B}%s${N}\n" "║" "          bapXaura understand" ""
  printf "${B}${C}%s${N}${B}%s${N}\n" "╚══════════════════════════════════════════╝" ""
  echo ""

  # ── Repository ──
  printf "${B}── Repository ──────────────────────────────${N}\n"
  echo "  Branch:      ${branch}"
  echo "  Last commit: ${last_commit}"
  echo "  Status:      ${git_status}"
  echo ""

  # ── Recent commits ──
  printf "${B}── Recent Commits ──────────────────────────${N}\n"
  git -C "$ROOT" log --oneline -5 2>/dev/null | sed 's/^/  /'
  echo ""

  # ── Schema Collections ──
  if [ -f "$SCHEMA_FILE" ]; then
    printf "${B}── Schema Collections ──────────────────────${N}\n"
    php -r "
      \$s = require '$SCHEMA_FILE';
      foreach (\$s['collections'] ?? [] as \$name => \$col) {
        echo \"  ${B}\${name}${N}\n\";
        echo \"    table:   \" . preg_replace('/[^a-z_]/', '', \$name) . \"\n\";
    echo \"    pkey:    \" . (\$col['primary_key'] ?? 'id') . \"\n\";
    echo \"    managed: \" . ((\$col['admin_managed'] ?? false) ? 'admin' : 'runtime') . \"\n\";
        if (\$col['admin_fields'] ?? []) echo \"    a_fields: \" . implode(', ', \$col['admin_fields']) . \"\n\";
        if (\$col['media_fields'] ?? []) echo \"    m_fields: \" . implode(', ', \$col['media_fields']) . \"\n\";
        if (\$col['agent_context'] ?? []) echo \"    context:  \" . implode(', ', \$col['agent_context']) . \"\n\";
        echo \"\";
        foreach (\$col['fields'] ?? [] as \$fname => \$fdef) {
          \$req = !empty(\$fdef['required']) ? ' (required)' : '';
          \$vals = isset(\$fdef['values']) ? ' [' . implode(', ', \$fdef['values']) . ']' : '';
          \$items = isset(\$fdef['items']) ? ' of ' . \$fdef['items'] : '';
          echo \"    ├─ \$fname: \" . \$fdef['type'] . \$items . \$vals . \$req . \"\n\";
        }
      }
    "
    echo ""
  fi

  # ── Skills ──
  local skills_root="$ROOT/.agents/skills"
  printf "${B}── Skills ──────────────────────────────────${N}\n"
  if [ -d "$skills_root" ]; then
    for skill_dir in "$skills_root"/*/; do
      [ -d "$skill_dir" ] || continue
      local sname; sname=$(basename "$skill_dir" 2>/dev/null) || true
      local sdesc
      sdesc=$(head -3 "$skill_dir/SKILL.md" 2>/dev/null | tail -1 | sed 's/^#* *//') || true
      sdesc="${sdesc:-Use when editing $sname tasks}"
      printf "  • %s  %s\n" "$sname" "$sdesc"
    done
  else
    echo "  (no skills directory found)"
  fi
  echo ""

  # ── AGENTS.md root excerpt ──
  if [ -f "$ROOT/AGENTS.md" ]; then
    printf "${B}── AGENTS.md Root (excerpt) ───────────────${N}\n"
    grep -v '^---$' "$ROOT/AGENTS.md" | grep -v '^globs:' | grep -v '^alwaysApply:' | grep -v '^description:' | head -12 | sed 's/^/  /'
    echo ""
  fi

  # ── Quick Reference ──
  printf "${B}── Quick Reference ─────────────────────────${N}\n"
  printf "  ${C}bapXaura test${N}        php tests/run.php\n"
  printf "  ${C}bapXaura serve${N}       php -S 127.0.0.1:6020 index.php\n"
  printf "  ${C}bapXaura ci${N}          lint → test → map validation → docs-map validation → smoke\n"
  printf "  ${C}bapXaura check${N}       alias for ci\n"
  printf "  ${C}bapXaura update${N}      regenerate and validate both repository maps\n"
  printf "  ${C}bapXaura db query <col>${N}  --where 'field=val' --limit 10\n"
  printf "  ${C}bapXaura db init${N}     create MySQL tables from schema\n"
  printf "  ${C}bapXaura db sync${N}     push JSON → MySQL\n"
  printf "  ${C}bapXaura understand${N}  Full project overview\n"
  printf "  ${C}bapXaura help${N}        All commands\n"
  echo ""
}

