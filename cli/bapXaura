# Load project and ignored operator connection settings for CLI subcommands.
for env_file in "$ROOT/.env" "$ROOT/.env.mysql" "$ROOT/.env.test-user"; do
if [ -f "$env_file" ]; then
  while IFS= read -r line || [ -n "$line" ]; do
    # Skip comments and empty lines
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    [[ -z "${line// }" ]] && continue
    # Strip carriage returns
    line=$(echo "$line" | tr -d '\r')
    if [[ "$line" =~ ^[A-Za-z_][A-Za-z0-9_]*= ]]; then
      eval "export $line"
    fi
  done < "$env_file"
fi
done

